<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/nara_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_title"
        android:textColor="@color/nara_text_primary"
        android:textStyle="bold"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/tv_permission_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/nara_status_offline"
        android:text="Izin mikrofon: memeriksa..." />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_expanded_mode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Mode widget expanded"
        android:textColor="@color/nara_text_primary" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_prefer_offline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Prioritaskan mode offline bila tersedia"
        android:textColor="@color/nara_text_primary" />

    <TextView
        android:id="@+id/tv_model_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textColor="@color/nara_text_secondary"
        android:text="Status model: belum dimuat" />

    <Button
        android:id="@+id/btn_pick_model"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Pilih Model GGUF..." />

    <ProgressBar
        android:id="@+id/progress_model_copy"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:max="100"
        android:visibility="gone" />

</LinearLayout>
