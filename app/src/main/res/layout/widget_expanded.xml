<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/nara_surface"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/nara_text_primary"
            android:textStyle="bold"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/indicator_connection"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/dot_indicator" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_idle"
            android:textColor="@color/nara_text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_last_response"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="@color/nara_text_primary"
        android:textSize="13sp"
        android:text="" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_mic"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_mic"
            android:background="@drawable/bg_mic_button"
            android:contentDescription="@string/action_mic" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:src="@drawable/ic_settings"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/action_settings" />

        <ImageButton
            android:id="@+id/btn_mode_toggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:src="@drawable/ic_offline"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="Mode offline/online" />

        <ImageButton
            android:id="@+id/btn_retry"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:visibility="gone"
            android:src="@drawable/ic_retry"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/action_retry" />
    </LinearLayout>

</LinearLayout>
