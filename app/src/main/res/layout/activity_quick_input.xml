<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="80dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_widget_pill"
    android:padding="8dp">

    <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="6dp"
        android:src="@mipmap/ic_launcher_round"
        android:contentDescription="@string/app_name" />

    <EditText
        android:id="@+id/et_quick_input"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:background="@null"
        android:hint="@string/quick_input_hint"
        android:textColor="@color/nara_text_primary"
        android:textColorHint="@color/nara_text_secondary"
        android:textSize="16sp"
        android:singleLine="true"
        android:imeOptions="actionSend"
        android:inputType="text" />

    <ImageButton
        android:id="@+id/btn_send"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_send"
        android:background="@drawable/bg_mic_button"
        android:contentDescription="@string/action_send" />

</LinearLayout>
