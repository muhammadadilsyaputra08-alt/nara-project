<?xml version="1.0" encoding="utf-8"?>
<!--
    Desain pill memanjang ala search-bar (mengikuti referensi widget Google Search):
    [logo Nara] [teks hint / respons terakhir, tap = input ketik] [dot online] [mic] [settings]

    Catatan sizing: appwidget-info targetCellWidth=4 / targetCellHeight=1 supaya launcher
    menawarkan bentuk memanjang satu baris ini sebagai ukuran default saat widget ditambahkan.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_widget_pill"
    android:paddingStart="6dp"
    android:paddingEnd="8dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <ImageView
        android:id="@+id/img_logo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@mipmap/ic_launcher_round"
        android:contentDescription="@string/app_name" />

    <TextView
        android:id="@+id/tv_last_response"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/nara_text_secondary"
        android:textSize="14sp"
        android:text="@string/widget_hint_placeholder" />

    <ImageView
        android:id="@+id/indicator_connection"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/dot_indicator" />

    <ImageButton
        android:id="@+id/btn_mic"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_mic"
        android:background="@drawable/bg_mic_button"
        android:contentDescription="@string/action_mic" />

    <ImageButton
        android:id="@+id/btn_settings"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginStart="6dp"
        android:src="@drawable/ic_settings"
        android:background="@drawable/bg_icon_button"
        android:contentDescription="@string/action_settings" />

    <!-- Tetap ada tapi tersembunyi: dipertahankan untuk kompatibilitas WidgetStateBinder,
         status detail sudah terwakili lewat teks di tv_last_response + warna dot. -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
